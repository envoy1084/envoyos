---
// oxlint-disable-next-line import/no-unassigned-import
import "../styles/global.css";

import { Font } from "astro:assets";
import { RootSeo } from "../components/seo";
import PostHog from "./posthog.astro";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <RootSeo />
    <PostHog />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-geist-mono" preload />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-100 focus:rounded-control focus:border focus:border-border-control focus:bg-surface-overlay focus:px-3 focus:py-2 focus:text-sm focus:text-text-default focus:shadow-menu"
    >
      Skip to content
    </a>

    <main id="main" class="root">
      <div class="max-w-sm mx-auto my-[10dvh] px-4">
        <slot />
      </div>
    </main>
  </body>
</html>
