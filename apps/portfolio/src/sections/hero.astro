---
import { Image } from "astro:assets";
import EnvoyLogo from "../assets/images/envoy1084.png";

import DotMorphCanvas from "../components/visuals/dot-morph-canvas";
import { RotatingTextAnimate } from "../components/ui/text-animate";

import MorphImage1 from "../assets/images/morph1.png?url";
import MorphImage2 from "../assets/images/morph2.png?url";
import MorphImage3 from "../assets/images/morph3.png?url";

const morphSources = [MorphImage3, MorphImage1, MorphImage2];

const titles = ["Software Engineer", "Technical Writer"];
---

<section id="hero" class="">
    <div class="flex flex-col gap-6">
        <div
            class="size-11 flex items-center justify-center rounded-lg bg-brand/30 shadow-card"
        >
            <Image
                src={EnvoyLogo}
                class="size-10 rounded-md overflow-hidden"
                alt="Envoy1084"
                loading="eager"
                fetchpriority="high"
                decoding="async"
            />
        </div>
        <div class="flex flex-col gap-0.5">
            <h1 class="text-xl font-semibold">Vedant Chainani</h1>
            <RotatingTextAnimate
                items={titles}
                intervalMs={5000}
                animation="cascade"
                className="text-content-tertiary text-[14px] font-medium"
                client:load
            />
        </div>
        <p class="text-content-secondary font-medium text-base">
            I'm a developer and writer. I work at Namespace on a mission to name
            a billion ethereum addresses. I've been coding for 3 years, still in
            beta learning my way through life.
        </p>
        <DotMorphCanvas sources={morphSources} client:only="react" />
    </div>
</section>
